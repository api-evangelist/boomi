  "info": {
    "_postman_id": "8f986de8-301c-4743-b665-1f5f85426ae4",
    "name": "Boomi Event Streams REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Boomi Event Streams REST API enables HTTP-based applications to produce messages to event topics. It supports two operational modes: multiple messages in a predefined JSON format, and single messages in their original format without transformation. The API accommodates messages up to 5 MB and enforces a rate limit of 60,000 requests per IP per 5-minute window. Each topic has a unique REST API URL available in the Event Streams UI. Authentication uses an Environment Token as a Bearer token.\n\nContact Support:\n Name: Boomi Support",
      "type": "text/plain"
    }
  }

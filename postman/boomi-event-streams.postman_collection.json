{
  "info": {
    "_postman_id": "9069c207-d437-4613-9f8a-f8fef73b8f8e",
    "name": "Boomi Event Streams REST API",
    "description": "The Boomi Event Streams REST API enables HTTP-based applications to produce messages to event topics. It supports two operational modes: multiple messages in a predefined JSON format, and single messages in their original format without transformation. The API accommodates messages up to 5 MB and enforces a rate limit of 60,000 requests per IP per 5-minute window. Each topic has a unique REST API URL available in the Event Streams UI. Authentication uses an Environment Token as a Bearer token.\n\nContact Support:\n Name: Boomi Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:05:57.000Z",
    "updatedAt": "2026-06-05T15:05:57.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-9069c207-d437-4613-9f8a-f8fef73b8f8e"
  },
